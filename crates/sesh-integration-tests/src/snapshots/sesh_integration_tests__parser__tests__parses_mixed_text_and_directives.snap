---
source: crates/sesh-integration-tests/src/parser.rs
expression: "Script::parse(&[r#\"# Scenario\"#, r#\"\"#, r#\":s cargo --version\"#,\nr#\":t new-session -d -s fixture \"sleep 3600\"\"#, r#\":p runner:0.0\"#,\nr#\":k down \"abc\"\"#, r#\":snap /foo/bar/\"#, r#\"\"#, r#\"Notes.\"#,\nr#\"\"#,].join(\"\\n\"))"
---
Script {
    lines: [
        Line {
            kind: Text,
            raw: "# Scenario",
        },
        Line {
            kind: Text,
            raw: "",
        },
        Line {
            kind: Sh {
                args: [
                    "cargo",
                    "--version",
                ],
            },
            raw: ":s cargo --version",
        },
        Line {
            kind: Tmux {
                args: [
                    "new-session",
                    "-d",
                    "-s",
                    "fixture",
                    "sleep 3600",
                ],
            },
            raw: ":t new-session -d -s fixture \"sleep 3600\"",
        },
        Line {
            kind: Pane {
                target: "runner:0.0",
            },
            raw: ":p runner:0.0",
        },
        Line {
            kind: Keys {
                keys: [
                    Key {
                        kind: Down,
                        ctrl: false,
                        meta: false,
                        shft: false,
                    },
                    Key {
                        kind: Text(
                            "abc",
                        ),
                        ctrl: false,
                        meta: false,
                        shft: false,
                    },
                ],
            },
            raw: ":k down \"abc\"",
        },
        Line {
            kind: Snap {
                filters: [
                    Filter {
                        patt: Regex(
                            "foo",
                        ),
                        repl: "bar",
                    },
                ],
            },
            raw: ":snap /foo/bar/",
        },
        Line {
            kind: Text,
            raw: "",
        },
        Line {
            kind: Text,
            raw: "Notes.",
        },
    ],
}
