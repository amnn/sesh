---
source: crates/sesh-integration-tests/src/parser.rs
expression: "Script::parse(&[\":snap /(a)(b)/x\", \"\"].join(\"\\n\"))"
---
Script {
    lines: [
        Line {
            kind: Snap {
                filters: [
                    Filter {
                        patt: Regex(
                            "(a)(b)",
                        ),
                        paint: 'x',
                    },
                ],
            },
            raw: ":snap /(a)(b)/x",
        },
    ],
}
