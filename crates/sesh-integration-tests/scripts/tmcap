#!/usr/bin/env python3
#
# Script used by tests to capture output into a file, while sending tmux
# signals to synchronize with the test runner.

from pathlib import Path
from subprocess import run
from sys import argv
from sys import stdin


def format_visible(data: bytes) -> str:
    out: list[str] = []

    for byte in data:
        if byte in (0x09, 0x0A, 0x0D) or 0x20 <= byte <= 0x7E:
            out.append(chr(byte))
        else:
            out.append(f"\\x{byte:02x}")

    return "".join(out)


def main() -> None:
    if len(argv) != 2:
        raise SystemExit("usage: tmcap <name>")

    name = argv[1]
    run(["tmux", "wait-for", "-S", f"ready-{name}"], check=True)

    data = format_visible(stdin.buffer.read())
    Path(f"{name}.txt").write_text(data, encoding="utf-8")
    run(["tmux", "wait-for", "-S", f"done-{name}"], check=True)


if __name__ == "__main__":
    main()
